generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql" // We are explicitly using Postgres
}

model User {
  id           String        @id @default(uuid())
  email        String        @unique
  reservations Reservation[]
  orders       Order[]
  createdAt    DateTime      @default(now())
}

model Product {
  id            String         @id @default(uuid())
  name          String
  stock         Int            @default(0) // The actual physical stock
  reservations  Reservation[]
  inventoryLogs InventoryLog[]
  updatedAt     DateTime       @updatedAt
}

model Reservation {
  id        String            @id @default(uuid())
  userId    String
  productId String
  quantity  Int
  status    ReservationStatus @default(PENDING)
  expiresAt DateTime          // Crucial for our 5-minute timeout
  
  user      User     @relation(fields: [userId], references: [id])
  product   Product  @relation(fields: [productId], references: [id])
  order     Order?   // Optional, because a reservation might expire before becoming an order

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Order {
  id            String   @id @default(uuid())
  reservationId String   @unique // One order comes from exactly one reservation
  userId        String
  
  reservation   Reservation @relation(fields: [reservationId], references: [id])
  user          User        @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())
}

model InventoryLog {
  id        String  @id @default(uuid())
  productId String
  type      LogType
  quantity  Int
  
  product   Product @relation(fields: [productId], references: [id])

  createdAt DateTime @default(now())
}

enum ReservationStatus {
  PENDING
  COMPLETED
  EXPIRED
}

enum LogType {
  RESERVED
  RELEASED
  PURCHASED
}